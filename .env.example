# gitgap — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gitgap
DB_USER=gitgap
DB_PASS=changeme

# ── NCBI / PubMed Central ─────────────────────────────────────────────────────
# Required: your email for polite API use (NCBI policy)
NCBI_EMAIL=your@email.com
# Optional: API key lifts rate limit from 3 to 10 req/sec
# Get at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=changeme
